f <- "2.4_clean_estimated_months/HKE_OTB_DWS_2019.CSV.csv"
file.exists(f)          # FALSE if not found
normalizePath(f, mustWork = FALSE)  # shows resolved path or the attempted path
find_existing_file <- function(path) {
if (file.exists(path)) return(normalizePath(path))
# try removing duplicated .csv/.CSV
p1 <- sub("\\.csv(\\.csv)?$", ".csv", path, ignore.case = TRUE)
if (file.exists(p1)) return(normalizePath(p1))
# try adding .CSV if missing
p2 <- if (!grepl("\\.csv$", path, ignore.case = TRUE)) paste0(path, ".CSV") else path
if (file.exists(p2)) return(normalizePath(p2))
# try case-insensitive search by basename
dir <- dirname(path)
base <- basename(path)
candidates <- list.files(dir, pattern = paste0("^", gsub("\\.", "\\\\.", base), "$"), ignore.case = TRUE, full.names = TRUE)
if (length(candidates) > 0) return(normalizePath(candidates[1]))
return(NULL)
}
f_try <- find_existing_file("2.4_clean_estimated_months/HKE_OTB_DWS_2019.CSV.csv")
if (is.null(f_try)) {
stop("File not found. Check the filename in the folder with list.files().")
} else {
r1 <- process_file(f_try)
}
process_file <- function(input_file, ...) {
if (!file.exists(input_file)) {
stop("Input file not found: ", input_file, ". Use list.files('folder') to inspect available files.")
}
# rest of function...
}
